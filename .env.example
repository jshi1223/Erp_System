NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_MAX_AGE_MS=86400000
JWT_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN_SECONDS=900

# PostgreSQL runtime database.
# For Supabase/Render, use the Supabase PostgreSQL connection string and set PGSSLMODE=require.
DATABASE_URL=postgresql://postgres:replace-with-password@localhost:5432/kinaadman
PGSSLMODE=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=uploads-pdf

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@kinaadman.local
# Optional comma-separated override. If blank, active admin and super_admin user emails receive approval notices.
APPROVAL_NOTIFY_EMAILS=

ALLOW_LEGACY_PLAINTEXT_PASSWORDS=true
